{
  "manifest_version": 3,
  "name": "DLP Paste Monitor PoC",
  "version": "1.0.0",
  "description": "Proof of concept — monitors paste events and displays a Shadow DOM tooltip.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
